# ============================================================================
# Example environment file.
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env        (macOS / Linux)
#   copy .env.example .env      (Windows)
#
# NEVER commit a real `.env` to git. The `.gitignore` is already set up to
# block it, but always double-check.
# ============================================================================

# --- PostgreSQL (used by the `db` service in docker-compose) ---
POSTGRES_USER=taskboard
POSTGRES_PASSWORD=taskboard
POSTGRES_DB=taskboard

# --- Backend (FastAPI) ---
# The backend reads DATABASE_URL to connect to Postgres.
# `db` is the docker-compose service name, which Docker turns into a hostname.
DATABASE_URL=postgresql+psycopg://taskboard:taskboard@db:5432/taskboard

# JWT secret used to sign session tokens. Anything long and random in dev.
# In production, use a real secret manager (we explain this in chapter 09).
JWT_SECRET=dev-only-please-change
JWT_EXPIRES_MINUTES=60

# --- Frontend (Express server) ---
# Inside Docker, the Express server talks to the backend via the
# internal service name `backend` on port 8000.
BACKEND_URL=http://backend:8000

# Port the Express server listens on (inside its own container).
PORT=3000
